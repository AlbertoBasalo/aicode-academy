---
interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
}

const {
  title,
  description,
  image: customImage,
  canonical: customCanonical,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const logo = "/logo_ai.png";
const motto = "Learn to code smarter";
const twitterHandle = "@AlbertoBasalo";
const siteName = "AI Code Academy";
const image = `https://aicode.academy/site-og-image.png?${new Date().toISOString().split("T")[0]}`;
---

<head>
  <script is:inline>
    (() => {
      const stored = localStorage.getItem("theme");
      const theme = stored === "light" || stored === "dark" ? stored : "dark";
      document.documentElement.setAttribute("data-theme", theme);
    })();
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href={logo} />
  <link rel="apple-touch-icon" href={logo} />
  <link rel="manifest" href="/manifest.json" />
  <meta name="generator" content={Astro.generator} />

  <!-- Main Meta Tags -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={customCanonical || canonicalURL} />

  <!-- Open Graph / Social Media Meta Tags -->
  <meta property="og:title" content={title + " | " + motto} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={customCanonical || canonicalURL} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:image" content={customImage || image} />
  <meta property="og:description" content={description} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content={twitterHandle} />
  <meta name="twitter:title" content={title + " | " + motto} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={customImage || image} />
</head>
