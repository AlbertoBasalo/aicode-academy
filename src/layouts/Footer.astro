---
import PrimaryComment from "@components/PrimaryComment.astro";
export type DocNavItem = {
  href: string;
  text: string;
  external?: boolean;
};
const GITHUB_REPO = "https://github.com/AIDDbot/AIDDbot";

export const DOC_NAV: DocNavItem[] = [
  { href: "/blog/es", text: "Blog" },
  { href: "/cursos", text: "Cursos" },
  { href: "/community", text: "Community" },
];
const currentYear = new Date().getFullYear();

const localLinks = [
  { href: "/blog/es", text: "Blog" },
  { href: "/cursos", text: "Cursos" },
  { href: "/community", text: "Community" },
];

const friendlyLinks = [
  { href: "https://albertobasalo.dev", text: "Alberto Basalo" },
  { href: "https://aiddbot.com", text: "AI-DD Bot" },
];

const links = [
  { href: "https://linkedin.com/in/albertobasalo", text: "LinkedIn" },
  { href: "https://github.com/AlbertoBasalo", text: "GitHub" },
  { href: "https://twitter.com/AlbertoBasalo", text: "Twitter" },
  { href: "https://www.youtube.com/c/AlbertoBasalo71", text: "YouTube" },
];

const legalLinks = [
  { href: "/legal/privacy/", text: "Privacy Policy" },
  { href: "/legal/terms/", text: "Terms of Service" },
  //{ href: "/legal/cookies/", text: "Cookie Policy" },
];
---

<footer>
  <main class="grid">
    <section>
      <h3 class="logo color"><a href="/">AI Code Academy</a></h3>
      <h4><PrimaryComment /> Learn to code smarter.</h4>
      <ul>
        {
          friendlyLinks.map((link) => (
            <li>
              <a href={link.href}>{link.text}</a>
            </li>
          ))
        }
      </ul>
    </section>
    <section>
      <h3>Docs</h3>
      <ul>
        {
          DOC_NAV.map((item) => (
            <li>
              <a
                href={item.href}
                {...(item.external && { target: "_blank", rel: "noopener" })}
              >
                {item.text}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
    <section>
      <h3>Connect</h3>
      <ul>
        {
          links.map((link) => (
            <li>
              <a href={link.href} target="_blank">
                {link.text}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
    <section>
      <h3>Legal</h3>
      <ul>
        {
          legalLinks.map((link) => (
            <li>
              <a href={link.href} target="_blank">
                {link.text}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
  <div>
    <p>
      &copy; {currentYear} AI Code Academy. All rights reserved. Created by <a
        href="https://albertobasalo.dev"
        target="_blank">Alberto Basalo</a
      >
    </p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--pico-primary);
    margin-top: 1rem;
  }
</style>
